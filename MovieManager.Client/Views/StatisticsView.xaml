<UserControl x:Class="MovieManager.Client.Views.StatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="900">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="0,0,0,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 标题 -->
            <TextBlock Grid.Row="0" Text="📊 统计面板" FontSize="28" FontWeight="Bold"
                       Margin="0,0,0,20" />

            <!-- 概览卡片 -->
            <WrapPanel Grid.Row="1" Margin="0,0,0,20">
                <Border Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="8" Width="170" Padding="16" Margin="0,0,12,12">
                    <StackPanel>
                        <TextBlock Text="总电影" FontSize="12"
                                   Foreground="{DynamicResource MaterialDesignHintForeground}" />
                        <TextBlock x:Name="TotalMoviesText" Text="0" FontSize="28"
                                   FontWeight="Bold" Foreground="#7C4DFF" />
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="8" Width="170" Padding="16" Margin="0,0,12,12">
                    <StackPanel>
                        <TextBlock Text="已看" FontSize="12"
                                   Foreground="{DynamicResource MaterialDesignHintForeground}" />
                        <TextBlock x:Name="WatchedText" Text="0" FontSize="28"
                                   FontWeight="Bold" Foreground="#4CAF50" />
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="8" Width="170" Padding="16" Margin="0,0,12,12">
                    <StackPanel>
                        <TextBlock Text="想看" FontSize="12"
                                   Foreground="{DynamicResource MaterialDesignHintForeground}" />
                        <TextBlock x:Name="WantWatchText" Text="0" FontSize="28"
                                   FontWeight="Bold" Foreground="#FF9800" />
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="8" Width="170" Padding="16" Margin="0,0,12,12">
                    <StackPanel>
                        <TextBlock Text="平均评分" FontSize="12"
                                   Foreground="{DynamicResource MaterialDesignHintForeground}" />
                        <TextBlock x:Name="AvgRatingText" Text="0.0" FontSize="28"
                                   FontWeight="Bold" Foreground="#E91E63" />
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="8" Width="170" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="⭐ 收藏" FontSize="12"
                                   Foreground="{DynamicResource MaterialDesignHintForeground}" />
                        <TextBlock x:Name="FavoritesText" Text="0" FontSize="28"
                                   FontWeight="Bold" Foreground="#FFC107" />
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- 图表行1：分类饼图 + 评分柱状图 -->
            <Grid Grid.Row="2" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- 分类分布饼图 -->
                <Border Grid.Column="0"
                        Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="8" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="📁 分类分布" FontSize="16"
                                   FontWeight="Bold" Margin="0,0,0,12" />
                        <lvc:PieChart x:Name="CategoryPieChart"
                                      Grid.Row="1" Height="280" />
                    </Grid>
                </Border>

                <!-- 评分分布柱状图 -->
                <Border Grid.Column="2"
                        Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="8" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="⭐ 评分分布" FontSize="16"
                                   FontWeight="Bold" Margin="0,0,0,12" />
                        <lvc:CartesianChart x:Name="RatingBarChart"
                                            Grid.Row="1" Height="280" />
                    </Grid>
                </Border>
            </Grid>

            <!-- 图表行2：年度趋势折线图 -->
            <Border Grid.Row="3"
                    Background="{DynamicResource MaterialDesignCardBackground}"
                    CornerRadius="8" Padding="16" Margin="0,0,0,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="📈 年度趋势" FontSize="16"
                               FontWeight="Bold" Margin="0,0,0,12" />
                    <lvc:CartesianChart x:Name="YearlyTrendChart"
                                        Grid.Row="1" Height="280" />
                </Grid>
            </Border>

            <!-- 图表行3：月度观影趋势 -->
            <Border Grid.Row="4"
                    Background="{DynamicResource MaterialDesignCardBackground}"
                    CornerRadius="8" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="📅 今年月度观影趋势" FontSize="16"
                               FontWeight="Bold" Margin="0,0,0,12" />
                    <lvc:CartesianChart x:Name="MonthlyWatchChart"
                                        Grid.Row="1" Height="280" />
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:EasyMovie.Client.Controls">

    <Style TargetType="{x:Type local:RangeSlider}">
        <Setter Property="Height" Value="36" />
        <Setter Property="Margin" Value="0,2,0,2" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:RangeSlider}">
                    <Grid VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- 标签行 -->
                        <Grid Margin="0,0,0,2">
                            <TextBlock Text="{TemplateBinding LowerText}"
                                       FontSize="11" Foreground="{DynamicResource MaterialDesignBody}"
                                       FontWeight="Medium"
                                       HorizontalAlignment="Left" Margin="6,0,0,0" />
                            <TextBlock Text="{TemplateBinding UpperText}"
                                       FontSize="11" Foreground="{DynamicResource MaterialDesignBody}"
                                       FontWeight="Medium"
                                       HorizontalAlignment="Right" Margin="0,0,6,0" />
                        </Grid>

                        <!-- 轨道区域 -->
                        <Grid x:Name="PART_Track" Grid.Row="1" Height="20"
                              ClipToBounds="False">
                            <!-- 背景轨道（深灰色） -->
                            <Border x:Name="TrackBackground"
                                    Background="#555555"
                                    CornerRadius="2" Height="4" VerticalAlignment="Center" />

                            <!-- 选中区域（主题色） -->
                            <Rectangle x:Name="PART_SelectionRange"
                                       Height="4" VerticalAlignment="Center" RadiusX="2" RadiusY="2"
                                       Fill="{DynamicResource PrimaryHueMidBrush}" HorizontalAlignment="Left" />

                            <!-- 左滑块（立体圆形） -->
                            <Thumb x:Name="PART_LowerThumb"
                                   Width="18" Height="18" Cursor="Hand" VerticalAlignment="Center" HorizontalAlignment="Left"
                                   Panel.ZIndex="1">
                                <Thumb.Template>
                                    <ControlTemplate TargetType="Thumb">
                                        <Grid>
                                            <!-- 阴影层 -->
                                            <Ellipse Fill="#20000000" Width="18" Height="18"
                                                     Margin="0,1,0,-1" />
                                            <!-- 主体 -->
                                            <Ellipse Width="18" Height="18">
                                                <Ellipse.Fill>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#AB47BC" Offset="0" />
                                                        <GradientStop Color="#7B1FA2" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Ellipse.Fill>
                                            </Ellipse>
                                            <!-- 高光 -->
                                            <Ellipse Fill="#40FFFFFF" Width="10" Height="6"
                                                     Margin="0,-3,0,0" VerticalAlignment="Center" />
                                        </Grid>
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>

                            <!-- 右滑块（立体圆形） -->
                            <Thumb x:Name="PART_UpperThumb"
                                   Width="18" Height="18" Cursor="Hand" VerticalAlignment="Center" HorizontalAlignment="Left"
                                   Panel.ZIndex="2">
                                <Thumb.Template>
                                    <ControlTemplate TargetType="Thumb">
                                        <Grid>
                                            <!-- 阴影层 -->
                                            <Ellipse Fill="#20000000" Width="18" Height="18"
                                                     Margin="0,1,0,-1" />
                                            <!-- 主体 -->
                                            <Ellipse Width="18" Height="18">
                                                <Ellipse.Fill>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#AB47BC" Offset="0" />
                                                        <GradientStop Color="#7B1FA2" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Ellipse.Fill>
                                            </Ellipse>
                                            <!-- 高光 -->
                                            <Ellipse Fill="#40FFFFFF" Width="10" Height="6"
                                                     Margin="0,-3,0,0" VerticalAlignment="Center" />
                                        </Grid>
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>
                        </Grid>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>

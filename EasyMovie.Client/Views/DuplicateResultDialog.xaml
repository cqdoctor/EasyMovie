<Window x:Class="EasyMovie.Client.Views.DuplicateResultDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="{DynamicResource Dup_DialogTitle}" Height="600" Width="680"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesignPaper}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock x:Name="ResultTitle" Grid.Row="0" FontSize="18" FontWeight="Bold"
                   Margin="0,0,0,16" Foreground="{DynamicResource MaterialDesignBody}" />

        <!-- 检测进度 -->
        <StackPanel x:Name="ProgressPanel" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <materialDesign:PackIcon Kind="Magnify" Width="48" Height="48"
                                     HorizontalAlignment="Center" Margin="0,0,0,12"
                                     Foreground="{DynamicResource MaterialDesignPrimary}" />
            <TextBlock x:Name="ProgressText" Text="{DynamicResource Dup_Detecting}"
                       HorizontalAlignment="Center" FontSize="16"
                       Foreground="{DynamicResource MaterialDesignBody}" />
            <ProgressBar x:Name="ProgressBar" IsIndeterminate="True" Width="300"
                         Margin="0,12,0,0" Style="{StaticResource MaterialDesignLinearProgressBar}" />
        </StackPanel>

        <!-- 结果列表 -->
        <ScrollViewer x:Name="ResultPanel" Grid.Row="1" Visibility="Collapsed"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="GroupItems">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource MaterialDesignCardBackground}"
                                CornerRadius="8" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <!-- 组标题 -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border CornerRadius="4" Padding="6,2" Margin="0,0,8,0"
                                            Background="{DynamicResource MaterialDesignPrimary}">
                                        <TextBlock Text="{Binding MatchTypeText}" FontSize="11"
                                                   Foreground="White" FontWeight="Bold" />
                                    </Border>
                                    <TextBlock Text="{Binding GroupKey}" FontSize="13"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}" />
                                </StackPanel>

                                <!-- 电影列表 -->
                                <ItemsControl ItemsSource="{Binding Movies}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderThickness="1" CornerRadius="6" Padding="10"
                                                    Margin="0,0,0,6"
                                                    BorderBrush="{DynamicResource MaterialDesignDivider}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <!-- 选择按钮 -->
                                                    <RadioButton Grid.Column="0" VerticalAlignment="Center"
                                                                 GroupName="{Binding GroupName}"
                                                                 IsChecked="{Binding IsPrimary}"
                                                                 Margin="0,0,10,0" />

                                                    <!-- 电影信息 -->
                                                    <StackPanel Grid.Column="1">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Title}" FontSize="14"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource MaterialDesignBody}" />
                                                            <TextBlock Text="{Binding YearText}" FontSize="12"
                                                                       Margin="8,0,0,0"
                                                                       Foreground="{DynamicResource MaterialDesignBodyLight}" />
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                            <TextBlock Text="{Binding RatingText}" FontSize="12"
                                                                       Margin="0,0,10,0"
                                                                       Foreground="#FFD700" />
                                                            <TextBlock Text="{Binding StatusText}" FontSize="12"
                                                                       Margin="0,0,10,0"
                                                                       Foreground="{DynamicResource MaterialDesignBodyLight}" />
                                                            <TextBlock Text="{Binding InfoText}" FontSize="11"
                                                                       Foreground="{DynamicResource MaterialDesignHintForeground}" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- 操作按钮 -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                                    <Button Content="{DynamicResource Dup_Merge}" Click="MergeGroup_Click"
                                            Style="{StaticResource MaterialDesignRaisedButton}"
                                            Height="28" FontSize="12" Margin="0,0,8,0"
                                            Tag="{Binding}" />
                                    <Button Content="{DynamicResource Dup_KeepAll}" Click="KeepAll_Click"
                                            Style="{StaticResource MaterialDesignFlatButton}"
                                            Height="28" FontSize="12"
                                            Tag="{Binding}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="MergeAllBtn" Content="{DynamicResource Dup_MergeAll}" Click="MergeAll_Click"
                    Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,0,8,0" Visibility="Collapsed" />
            <Button Content="{DynamicResource Msg_Cancel}" Click="Close_Click"
                    Style="{StaticResource MaterialDesignFlatButton}" />
        </StackPanel>
    </Grid>
</Window>

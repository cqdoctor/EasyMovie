<UserControl x:Class="EasyMovie.Client.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="700">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="0,0,0,24">
            <StackPanel>
                <TextBlock Text="{DynamicResource Settings_Title}" FontSize="28" FontWeight="Bold" Margin="0,0,0,24" />

                <Border Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="8" Padding="24" Margin="0,0,0,16">
                    <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="{DynamicResource Settings_Theme}" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>
                        <StackPanel Grid.Row="1" Orientation="Horizontal">
                            <Button x:Name="SystemThemeBtn" Style="{StaticResource MaterialDesignRaisedButton}" Click="SystemTheme_Click" Width="120" Height="80" Margin="0,0,12,0">
                                <Button.ContentTemplate><DataTemplate><StackPanel><materialDesign:PackIcon Kind="Monitor" Width="24" Height="24"/><TextBlock Text="{DynamicResource Settings_ThemeSystem}" Margin="0,4,0,0" HorizontalAlignment="Center"/></StackPanel></DataTemplate></Button.ContentTemplate>
                            </Button>
                            <Button x:Name="DarkThemeBtn" Style="{StaticResource MaterialDesignRaisedButton}" Click="DarkTheme_Click" Width="120" Height="80" Margin="0,0,12,0">
                                <Button.ContentTemplate><DataTemplate><StackPanel><materialDesign:PackIcon Kind="WeatherNight" Width="24" Height="24"/><TextBlock Text="{DynamicResource Settings_ThemeDark}" Margin="0,4,0,0" HorizontalAlignment="Center"/></StackPanel></DataTemplate></Button.ContentTemplate>
                            </Button>
                            <Button x:Name="LightThemeBtn" Style="{StaticResource MaterialDesignRaisedButton}" Click="LightTheme_Click" Width="120" Height="80">
                                <Button.ContentTemplate><DataTemplate><StackPanel><materialDesign:PackIcon Kind="WhiteBalanceSunny" Width="24" Height="24"/><TextBlock Text="{DynamicResource Settings_ThemeLight}" Margin="0,4,0,0" HorizontalAlignment="Center"/></StackPanel></DataTemplate></Button.ContentTemplate>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 语言设置 -->
                <Border Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="8" Padding="24" Margin="0,0,0,16">
                    <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="{DynamicResource Settings_Language}" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>
                        <StackPanel Grid.Row="1" Orientation="Horizontal">
                            <Button x:Name="ZhLangBtn" Style="{StaticResource MaterialDesignRaisedButton}" Click="ZhLang_Click" Width="120" Height="80" Margin="0,0,12,0">
                                <Button.ContentTemplate><DataTemplate><StackPanel><TextBlock Text="中文" FontSize="20" HorizontalAlignment="Center"/><TextBlock Text="简体中文" FontSize="11" Margin="0,2,0,0" HorizontalAlignment="Center" Foreground="{DynamicResource MaterialDesignHintForeground}"/></StackPanel></DataTemplate></Button.ContentTemplate>
                            </Button>
                            <Button x:Name="EnLangBtn" Style="{StaticResource MaterialDesignRaisedButton}" Click="EnLang_Click" Width="120" Height="80">
                                <Button.ContentTemplate><DataTemplate><StackPanel><TextBlock Text="En" FontSize="20" HorizontalAlignment="Center"/><TextBlock Text="English" FontSize="11" Margin="0,2,0,0" HorizontalAlignment="Center" Foreground="{DynamicResource MaterialDesignHintForeground}"/></StackPanel></DataTemplate></Button.ContentTemplate>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- TMDB Key -->
                <Border Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="8" Padding="24" Margin="0,0,0,16">
                    <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="{DynamicResource Settings_Network}" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>
                        <StackPanel Grid.Row="1">
                            <TextBox x:Name="TmdbKeyBox" materialDesign:HintAssist.Hint="TMDB API Key" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Width="350" Margin="0,0,0,8"/>
                            <TextBox x:Name="ProxyBox" materialDesign:HintAssist.Hint="{DynamicResource Settings_ProxyHint}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Width="350" Margin="0,0,0,8"/>
                            <TextBox x:Name="DoubanCookieBox" materialDesign:HintAssist.Hint="{DynamicResource Settings_CookieHint}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Width="400" Margin="0,0,0,8" TextWrapping="Wrap" MinHeight="50"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="{DynamicResource Settings_Save}" Style="{StaticResource MaterialDesignFlatButton}" Click="SaveNetwork_Click" Margin="0,0,8,0"/>
                                <TextBlock Text="TMDB Key: themoviedb.org/settings/api" FontSize="11" Foreground="{DynamicResource MaterialDesignHintForeground}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 数据管理 -->
                <Border Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="8" Padding="24" Margin="0,0,0,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="{DynamicResource Settings_DataManagement}" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>

                        <!-- 导入文件夹 -->
                        <StackPanel Grid.Row="1" Margin="0,0,0,12" Orientation="Horizontal">
                            <TextBox x:Name="FolderPathBox" Width="300" materialDesign:HintAssist.Hint="{DynamicResource Settings_FolderPath}"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,8,0" />
                            <Button Content="{DynamicResource Settings_ImportFolderBtn}" Style="{StaticResource MaterialDesignRaisedButton}" Click="ImportFolder_Click" Margin="0,0,8,0"/>
                            <CheckBox x:Name="RecursiveCheck" Content="{DynamicResource Settings_IncludeSubfolders}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- 导出 -->
                        <StackPanel Grid.Row="2" Margin="0,0,0,12" Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource Settings_Export}" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Button Content="CSV" Style="{StaticResource MaterialDesignRaisedButton}" Click="ExportCsv_Click" Margin="0,0,6,0"/>
                            <Button Content="JSON" Style="{StaticResource MaterialDesignRaisedButton}" Click="ExportJson_Click" Margin="0,0,6,0"/>
                            <Button Content="{DynamicResource Settings_FullBackup}" Style="{StaticResource MaterialDesignRaisedButton}" Click="ExportFullBackup_Click"/>
                        </StackPanel>

                        <!-- 导入 -->
                        <StackPanel Grid.Row="3" Margin="0,0,0,12" Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource Settings_Import}" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Button Content="CSV" Style="{StaticResource MaterialDesignRaisedButton}" Click="ImportCsv_Click" Margin="0,0,6,0"/>
                            <Button Content="JSON" Style="{StaticResource MaterialDesignRaisedButton}" Click="ImportJson_Click" Margin="0,0,6,0"/>
                            <Button Content="{DynamicResource Settings_RestoreData}" Style="{StaticResource MaterialDesignRaisedButton}" Click="RestoreBackup_Click"/>
                        </StackPanel>

                        <!-- 自动备份配置 -->
                        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="{DynamicResource Backup_Interval}" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="BackupIntervalCombo" Style="{StaticResource MaterialDesignComboBox}" FontSize="13" Width="120" SelectionChanged="BackupInterval_Changed">
                                <ComboBoxItem Content="{DynamicResource Backup_Daily}" Tag="1" />
                                <ComboBoxItem Content="{DynamicResource Backup_Weekly}" Tag="7" />
                                <ComboBoxItem Content="{DynamicResource Backup_Monthly}" Tag="30" />
                                <ComboBoxItem Content="{DynamicResource Backup_Disabled}" Tag="0" />
                            </ComboBox>
                            <TextBlock Text="{DynamicResource Backup_MaxCount}" FontSize="13" VerticalAlignment="Center" Margin="24,0,8,0"/>
                            <ComboBox x:Name="MaxBackupCombo" Style="{StaticResource MaterialDesignComboBox}" FontSize="13" Width="80" SelectionChanged="MaxBackup_Changed">
                                <ComboBoxItem Content="5" Tag="5" />
                                <ComboBoxItem Content="10" Tag="10" />
                                <ComboBoxItem Content="20" Tag="20" />
                                <ComboBoxItem Content="50" Tag="50" />
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Content="{DynamicResource Backup_ManualBackup}" Style="{StaticResource MaterialDesignRaisedButton}" Click="ManualBackup_Click" Margin="0,0,8,0"/>
                            <Button Content="{DynamicResource Backup_OpenFolder}" Style="{StaticResource MaterialDesignFlatButton}" Click="OpenBackupFolder_Click"/>
                        </StackPanel>

                        <!-- 备份历史 -->
                        <TextBlock Grid.Row="7" Text="{DynamicResource Backup_History}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ListBox Grid.Row="8" x:Name="BackupHistoryList" MaxHeight="200"
                                 materialDesign:ListBoxItemAssist.ShowSelection="False" Margin="0,0,0,0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding DisplayText}" FontSize="12" VerticalAlignment="Center" />
                                        <Button Grid.Column="1" Content="{DynamicResource Backup_Restore}" Style="{StaticResource MaterialDesignFlatButton}" FontSize="11"
                                                Click="RestoreBackupItem_Click" Tag="{Binding FilePath}" Margin="4,0" />
                                        <Button Grid.Column="2" Content="{DynamicResource Backup_Delete}" Style="{StaticResource MaterialDesignFlatButton}" FontSize="11"
                                                Click="DeleteBackupItem_Click" Tag="{Binding FilePath}" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- 分类与标签 -->
                <Border Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="8" Padding="24" Margin="0,0,0,16">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="{DynamicResource CatTag_Title}" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>
                        <StackPanel Grid.Row="1">
                            <TextBlock Text="{DynamicResource Settings_CatTagHint}" FontSize="13"
                                       Foreground="{DynamicResource MaterialDesignHintForeground}" Margin="0,0,0,12" TextWrapping="Wrap"/>
                            <Button x:Name="ManageCatTagBtn" Content="{DynamicResource Settings_ManageCatTag}"
                                    Style="{StaticResource MaterialDesignRaisedButton}" Click="ManageCatTag_Click" HorizontalAlignment="Left" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 工具 -->
                <Border Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="8" Padding="24" Margin="0,0,0,16">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="{DynamicResource Settings_Tools}" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>
                        <StackPanel Grid.Row="1">
                            <Button x:Name="DetectDuplicatesBtn" Content="{DynamicResource Settings_DetectDuplicates}"
                                    Style="{StaticResource MaterialDesignRaisedButton}" Click="DetectDuplicates_Click" HorizontalAlignment="Left" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 快捷键设置 -->
                <Border Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="8" Padding="24" Margin="0,0,0,16">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="{DynamicResource Settings_Shortcuts}" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>
                        <StackPanel Grid.Row="1">
                            <TextBlock Text="{DynamicResource Shortcuts_SettingsHint}" FontSize="13" Foreground="{DynamicResource MaterialDesignHintForeground}" Margin="0,0,0,12" TextWrapping="Wrap"/>
                            <Button x:Name="ConfigureShortcutsBtn"
                                    Content="{DynamicResource Settings_ConfigureShortcuts}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Click="ConfigureShortcuts_Click" HorizontalAlignment="Left" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="8" Padding="24">
                    <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="{DynamicResource Settings_About}" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>
                        <StackPanel Grid.Row="1">
                            <TextBlock Text="EasyMovie v1.02" FontSize="14" FontWeight="Bold"/>
                            <TextBlock Text="WPF + .NET 10 + SQLite" FontSize="13" Foreground="{DynamicResource MaterialDesignHintForeground}"/>
                            <TextBlock Text="{DynamicResource Settings_DataSources}" FontSize="13" Foreground="{DynamicResource MaterialDesignHintForeground}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>

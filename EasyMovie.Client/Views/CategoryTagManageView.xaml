<UserControl x:Class="EasyMovie.Client.Views.CategoryTagManageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="900">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{DynamicResource CatTag_Title}" FontSize="28" FontWeight="Bold" Margin="0,0,0,16" />

        <TabControl Grid.Row="1" Style="{StaticResource MaterialDesignTabControl}">
            <!-- 分类管理 Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Margin="4,0">
                        <materialDesign:PackIcon Kind="FolderOutline" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="{DynamicResource CatTag_CategoryTab}" VerticalAlignment="Center" FontSize="13" />
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{DynamicResource MaterialDesignCardBackground}"
                            CornerRadius="8" Padding="12" Margin="0,0,12,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <TextBlock Text="{DynamicResource CatTag_CategoryTree}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                        HorizontalAlignment="Right" Click="AddRootCategory_Click" ToolTip="{DynamicResource CatTag_AddRoot}">
                                    <materialDesign:PackIcon Kind="FolderPlus" />
                                </Button>
                            </Grid>
                            <TreeView x:Name="CategoryTree" Grid.Row="1"
                                      SelectedItemChanged="CategoryTree_SelectedItemChanged"
                                      Style="{StaticResource MaterialDesignTreeView}">
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="FolderOutline" Width="16" Height="16"
                                                                     VerticalAlignment="Center" Margin="0,0,6,0" />
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Background="{DynamicResource MaterialDesignCardBackground}"
                            CornerRadius="8" Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="FormTitle" Grid.Row="0" Text="{DynamicResource CatTag_SelectOrAdd}"
                                       FontSize="18" FontWeight="Bold" Margin="0,0,0,16" />
                            <TextBox x:Name="CategoryNameBox" Grid.Row="1"
                                     materialDesign:HintAssist.Hint="{DynamicResource CatTag_CategoryName}"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,10" />
                            <TextBox x:Name="CategoryDescBox" Grid.Row="2"
                                     materialDesign:HintAssist.Hint="{DynamicResource CatTag_Description}"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                     TextWrapping="Wrap" AcceptsReturn="True" MinHeight="50" MaxHeight="80" Margin="0,0,0,10" />
                            <TextBlock x:Name="ParentInfo" Grid.Row="3"
                                       Foreground="{DynamicResource MaterialDesignHintForeground}" FontSize="12" Margin="0,0,0,10" />
                            <TextBlock x:Name="StatInfo" Grid.Row="4"
                                       Foreground="{DynamicResource MaterialDesignHintForeground}" FontSize="12" />
                            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                <Button x:Name="DeleteBtn" Content="{DynamicResource CatTag_Delete}" Style="{StaticResource MaterialDesignFlatButton}"
                                        Foreground="{DynamicResource MaterialDesignErrorForeground}"
                                        Click="DeleteBtn_Click" Margin="0,0,8,0" />
                                <Button x:Name="AddChildBtn" Content="{DynamicResource CatTag_AddChild}" Style="{StaticResource MaterialDesignFlatButton}"
                                        Click="AddChildBtn_Click" Margin="0,0,8,0" />
                                <Button Content="{DynamicResource CatTag_Save}" Style="{StaticResource MaterialDesignRaisedButton}" Click="SaveBtn_Click" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- 标签管理 Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Margin="4,0">
                        <materialDesign:PackIcon Kind="TagOutline" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="{DynamicResource CatTag_TagTab}" VerticalAlignment="Center" FontSize="13" />
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{DynamicResource MaterialDesignCardBackground}"
                            CornerRadius="8" Padding="12" Margin="0,0,12,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <TextBlock Text="{DynamicResource CatTag_TagList}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                        HorizontalAlignment="Right" Click="AddTag_Click" ToolTip="{DynamicResource CatTag_AddTag}">
                                    <materialDesign:PackIcon Kind="TagPlus" />
                                </Button>
                            </Grid>
                            <ListBox x:Name="TagListBox" Grid.Row="1" SelectionChanged="TagListBox_SelectionChanged"
                                     Style="{StaticResource MaterialDesignListBox}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="14" Height="14" CornerRadius="3"
                                                    Background="{Binding Color, FallbackValue=Gray}"
                                                    VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="13" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Background="{DynamicResource MaterialDesignCardBackground}"
                            CornerRadius="8" Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="TagFormTitle" Grid.Row="0" Text="{DynamicResource CatTag_SelectOrAddTag}"
                                       FontSize="18" FontWeight="Bold" Margin="0,0,0,16" />
                            <TextBox x:Name="TagNameBox" Grid.Row="1"
                                     materialDesign:HintAssist.Hint="{DynamicResource CatTag_TagName}"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,12" />
                            <TextBlock Grid.Row="2" Text="{DynamicResource CatTag_TagColor}" FontSize="12"
                                       Foreground="{DynamicResource MaterialDesignHintForeground}" Margin="0,0,0,6" />
                            <StackPanel Grid.Row="3" Orientation="Horizontal" x:Name="ColorPicker" Margin="0,0,0,10" />
                            <Border x:Name="ColorPreview" Grid.Row="4" Width="60" Height="60" CornerRadius="8"
                                    Background="Gray" HorizontalAlignment="Left" VerticalAlignment="Top" />
                            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                <Button x:Name="TagDeleteBtn" Content="{DynamicResource CatTag_Delete}" Style="{StaticResource MaterialDesignFlatButton}"
                                        Foreground="{DynamicResource MaterialDesignErrorForeground}"
                                        Click="DeleteTag_Click" Margin="0,0,8,0" />
                                <Button Content="{DynamicResource CatTag_Save}" Style="{StaticResource MaterialDesignRaisedButton}" Click="SaveTag_Click" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>

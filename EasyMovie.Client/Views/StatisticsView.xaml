<UserControl x:Class="EasyMovie.Client.Views.StatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="900"
             UseLayoutRounding="True">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="8,0,8,24">

            <TextBlock Text="{DynamicResource Stats_Title}" FontSize="28" FontWeight="Bold"
                       Margin="8,0,0,20" />

            <!-- 概览卡片 - 渐变背景 -->
            <WrapPanel Margin="0,0,0,20">
                <!-- 总电影数 -->
                <Border CornerRadius="12" Width="155" Padding="16,14" Margin="0,0,10,10">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#7C4DFF" Offset="0"/>
                            <GradientStop Color="#B388FF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#7C4DFF" Opacity="0.3" BlurRadius="8" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Stats_TotalMovies}" FontSize="11"
                                   Foreground="#FFFFFFCC" />
                        <TextBlock x:Name="TotalMoviesText" Text="0" FontSize="30"
                                   FontWeight="Bold" Foreground="White" />
                    </StackPanel>
                </Border>
                <!-- 已看 -->
                <Border CornerRadius="12" Width="155" Padding="16,14" Margin="0,0,10,10">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#4CAF50" Offset="0"/>
                            <GradientStop Color="#81C784" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#4CAF50" Opacity="0.3" BlurRadius="8" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Stats_Watched}" FontSize="11"
                                   Foreground="#FFFFFFCC" />
                        <TextBlock x:Name="WatchedText" Text="0" FontSize="30"
                                   FontWeight="Bold" Foreground="White" />
                    </StackPanel>
                </Border>
                <!-- 想看 -->
                <Border CornerRadius="12" Width="155" Padding="16,14" Margin="0,0,10,10">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF9800" Offset="0"/>
                            <GradientStop Color="#FFB74D" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#FF9800" Opacity="0.3" BlurRadius="8" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Stats_WantWatch}" FontSize="11"
                                   Foreground="#FFFFFFCC" />
                        <TextBlock x:Name="WantWatchText" Text="0" FontSize="30"
                                   FontWeight="Bold" Foreground="White" />
                    </StackPanel>
                </Border>
                <!-- 平均评分 -->
                <Border CornerRadius="12" Width="155" Padding="16,14" Margin="0,0,10,10">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#E91E63" Offset="0"/>
                            <GradientStop Color="#F48FB1" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#E91E63" Opacity="0.3" BlurRadius="8" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Stats_AvgRating}" FontSize="11"
                                   Foreground="#FFFFFFCC" />
                        <TextBlock x:Name="AvgRatingText" Text="0.0" FontSize="30"
                                   FontWeight="Bold" Foreground="White" />
                    </StackPanel>
                </Border>
                <!-- 收藏 -->
                <Border CornerRadius="12" Width="155" Padding="16,14" Margin="0,0,10,10">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FFC107" Offset="0"/>
                            <GradientStop Color="#FFD54F" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#FFC107" Opacity="0.3" BlurRadius="8" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Stats_Favorites}" FontSize="11"
                                   Foreground="#FFFFFFCC" />
                        <TextBlock x:Name="FavoritesText" Text="0" FontSize="30"
                                   FontWeight="Bold" Foreground="White" />
                    </StackPanel>
                </Border>
                <!-- 总时长 -->
                <Border CornerRadius="12" MinWidth="155" Padding="16,14" Margin="0,0,10,10">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#00BCD4" Offset="0"/>
                            <GradientStop Color="#4DD0E1" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#00BCD4" Opacity="0.3" BlurRadius="8" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Stats_TotalRuntime}" FontSize="11"
                                   Foreground="#FFFFFFCC" />
                        <TextBlock x:Name="TotalRuntimeText" Text="0" FontSize="22"
                                   FontWeight="Bold" Foreground="White" />
                    </StackPanel>
                </Border>
                <!-- 观影完成率 -->
                <Border CornerRadius="12" Width="155" Padding="16,14" Margin="0,0,10,10">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#66BB6A" Offset="0"/>
                            <GradientStop Color="#A5D6A7" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#66BB6A" Opacity="0.3" BlurRadius="8" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Stats_CompletionRate}" FontSize="11"
                                   Foreground="#FFFFFFCC" />
                        <TextBlock x:Name="CompletionRateText" Text="0%" FontSize="30"
                                   FontWeight="Bold" Foreground="White" />
                        <Border Background="#FFFFFF44" CornerRadius="3" Height="6" Margin="0,6,0,0">
                            <Border x:Name="CompletionRateBar" Background="White" CornerRadius="3"
                                    HorizontalAlignment="Left" Width="0" Height="6" Opacity="0.9"/>
                        </Border>
                    </StackPanel>
                </Border>
                <!-- 今年观影 -->
                <Border CornerRadius="12" MinWidth="155" Padding="16,14" Margin="0,0,0,10">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#AB47BC" Offset="0"/>
                            <GradientStop Color="#CE93D8" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#AB47BC" Opacity="0.3" BlurRadius="8" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Stats_ThisYear}" FontSize="11"
                                   Foreground="#FFFFFFCC" />
                        <TextBlock x:Name="ThisYearWatchedText" Text="0" FontSize="22"
                                   FontWeight="Bold" Foreground="White" />
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- 评分分布 & 年度趋势 -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="12" Padding="20,16">
                    <Border.Effect>
                        <DropShadowEffect Color="#00000022" BlurRadius="6" ShadowDepth="1"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="4" Height="20" CornerRadius="2" Background="#7C4DFF" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource Stats_RatingDist}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ItemsControl x:Name="RatingChart">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2" Height="24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="36" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Label}" FontSize="11"
                                                   VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesignHintForeground}"/>
                                        <Border Grid.Column="1" Background="#E8E0F7" CornerRadius="4" Height="16" VerticalAlignment="Center">
                                            <Border Background="#7C4DFF" CornerRadius="4"
                                                    HorizontalAlignment="Left"
                                                    Width="{Binding BarWidth}" Height="16" />
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{Binding CountText}" FontSize="11"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                                   FontWeight="SemiBold" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="12" Padding="20,16">
                    <Border.Effect>
                        <DropShadowEffect Color="#00000022" BlurRadius="6" ShadowDepth="1"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="4" Height="20" CornerRadius="2" Background="#4CAF50" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource Stats_YearlyTrend}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ItemsControl x:Name="YearlyChart">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2" Height="24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="44" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding YearText}" FontSize="11"
                                                   VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesignHintForeground}"/>
                                        <Border Grid.Column="1" Background="#E8F5E9" CornerRadius="4" Height="16" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Background="#7C4DFF" CornerRadius="4,0,0,4"
                                                        HorizontalAlignment="Left"
                                                        Width="{Binding AddedWidth}" Height="16" />
                                                <Border Background="#4CAF50" CornerRadius="0,4,4,0"
                                                        HorizontalAlignment="Left"
                                                        Width="{Binding WatchedWidth}" Height="16" />
                                            </StackPanel>
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{Binding YearSummary}" FontSize="10"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                                   Foreground="{DynamicResource MaterialDesignHintForeground}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Border Width="12" Height="12" Background="#7C4DFF" CornerRadius="3" Margin="0,0,4,0" />
                            <TextBlock Text="{DynamicResource Stats_Total}" FontSize="10" Margin="0,0,14,0" Foreground="{DynamicResource MaterialDesignHintForeground}"/>
                            <Border Width="12" Height="12" Background="#4CAF50" CornerRadius="3" Margin="0,0,4,0" />
                            <TextBlock Text="{DynamicResource Stats_Watched}" FontSize="10" Foreground="{DynamicResource MaterialDesignHintForeground}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 月度观影 & 国家/地区分布 -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="12" Padding="20,16">
                    <Border.Effect>
                        <DropShadowEffect Color="#00000022" BlurRadius="6" ShadowDepth="1"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="4" Height="20" CornerRadius="2" Background="#00BCD4" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource Stats_MonthlyTrend}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ItemsControl x:Name="MonthlyChart">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2" Height="24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="30" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding MonthText}" FontSize="11"
                                                   VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesignHintForeground}"/>
                                        <Border Grid.Column="1" Background="#E0F7FA" CornerRadius="4" Height="16" VerticalAlignment="Center">
                                            <Border Background="#00BCD4" CornerRadius="4"
                                                    HorizontalAlignment="Left"
                                                    Width="{Binding BarWidth}" Height="16" />
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{Binding CountText}" FontSize="11"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                                   FontWeight="SemiBold" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="12" Padding="20,16">
                    <Border.Effect>
                        <DropShadowEffect Color="#00000022" BlurRadius="6" ShadowDepth="1"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="4" Height="20" CornerRadius="2" Background="#FF9800" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource Stats_CountryDist}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ItemsControl x:Name="CountryChart">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2" Height="24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="36" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" FontSize="11"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Name}" Foreground="{DynamicResource MaterialDesignHintForeground}"/>
                                        <Border Grid.Column="1" Background="#FFF3E0" CornerRadius="4" Height="16" VerticalAlignment="Center">
                                            <Border Background="#FF9800" CornerRadius="4"
                                                    HorizontalAlignment="Left"
                                                    Width="{Binding BarWidth}" Height="16" />
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{Binding CountText}" FontSize="11"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                                   FontWeight="SemiBold" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 导演排行 & 演员排行 -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="12" Padding="20,16">
                    <Border.Effect>
                        <DropShadowEffect Color="#00000022" BlurRadius="6" ShadowDepth="1"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="4" Height="20" CornerRadius="2" Background="#9C27B0" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource Stats_DirectorRank}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ItemsControl x:Name="DirectorChart">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3" Height="26">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="26" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="36" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="22" Height="22" CornerRadius="11" Background="#F3E5F5" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Rank}" FontSize="10" FontWeight="Bold"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                                       Foreground="#9C27B0" />
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Name}" />
                                        <Border Grid.Column="2" Background="#F3E5F5" CornerRadius="4" Height="16" VerticalAlignment="Center">
                                            <Border Background="#9C27B0" CornerRadius="4"
                                                    HorizontalAlignment="Left"
                                                    Width="{Binding BarWidth}" Height="16" />
                                        </Border>
                                        <TextBlock Grid.Column="3" Text="{Binding CountText}" FontSize="11"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                                   FontWeight="SemiBold" Foreground="{DynamicResource MaterialDesignHintForeground}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="12" Padding="20,16">
                    <Border.Effect>
                        <DropShadowEffect Color="#00000022" BlurRadius="6" ShadowDepth="1"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="4" Height="20" CornerRadius="2" Background="#FF5722" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource Stats_CastRank}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ItemsControl x:Name="CastChart">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3" Height="26">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="26" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="36" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="22" Height="22" CornerRadius="11" Background="#FBE9E7" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Rank}" FontSize="10" FontWeight="Bold"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                                       Foreground="#FF5722" />
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Name}" />
                                        <Border Grid.Column="2" Background="#FBE9E7" CornerRadius="4" Height="16" VerticalAlignment="Center">
                                            <Border Background="#FF5722" CornerRadius="4"
                                                    HorizontalAlignment="Left"
                                                    Width="{Binding BarWidth}" Height="16" />
                                        </Border>
                                        <TextBlock Grid.Column="3" Text="{Binding CountText}" FontSize="11"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                                   FontWeight="SemiBold" Foreground="{DynamicResource MaterialDesignHintForeground}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 类型分布 & 最活跃星期 -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="12" Padding="20,16">
                    <Border.Effect>
                        <DropShadowEffect Color="#00000022" BlurRadius="6" ShadowDepth="1"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="4" Height="20" CornerRadius="2" Background="#3F51B5" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource Stats_GenreDist}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ItemsControl x:Name="GenreChart">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2" Height="24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="36" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" FontSize="11"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Name}" Foreground="{DynamicResource MaterialDesignHintForeground}"/>
                                        <Border Grid.Column="1" Background="#E8EAF6" CornerRadius="4" Height="16" VerticalAlignment="Center">
                                            <Border Background="#3F51B5" CornerRadius="4"
                                                    HorizontalAlignment="Left"
                                                    Width="{Binding BarWidth}" Height="16" />
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{Binding CountText}" FontSize="11"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                                   FontWeight="SemiBold" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="12" Padding="20,16">
                    <Border.Effect>
                        <DropShadowEffect Color="#00000022" BlurRadius="6" ShadowDepth="1"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="4" Height="20" CornerRadius="2" Background="#FF5722" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource Stats_DayOfWeek}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ItemsControl x:Name="DayOfWeekChart">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2" Height="24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="36" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding DayName}" FontSize="11"
                                                   VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesignHintForeground}"/>
                                        <Border Grid.Column="1" Background="#FBE9E7" CornerRadius="4" Height="16" VerticalAlignment="Center">
                                            <Border Background="#FF5722" CornerRadius="4"
                                                    HorizontalAlignment="Left"
                                                    Width="{Binding BarWidth}" Height="16" />
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{Binding CountText}" FontSize="11"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                                   FontWeight="SemiBold" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 片长分布 & 最长连续观影 -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="12" Padding="20,16">
                    <Border.Effect>
                        <DropShadowEffect Color="#00000022" BlurRadius="6" ShadowDepth="1"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="4" Height="20" CornerRadius="2" Background="#FF9800" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource Stats_RuntimeDist}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ItemsControl x:Name="RuntimeChart">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2" Height="24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="36" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Label}" FontSize="11"
                                                   VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesignHintForeground}"/>
                                        <Border Grid.Column="1" Background="#FFF3E0" CornerRadius="4" Height="16" VerticalAlignment="Center" MinWidth="120">
                                            <Border Background="#FF9800" CornerRadius="4"
                                                    HorizontalAlignment="Left"
                                                    Width="{Binding BarWidth}" Height="16" />
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{Binding CountText}" FontSize="11"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                                   FontWeight="SemiBold" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" CornerRadius="12" Padding="20,16">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF5722" Offset="0"/>
                            <GradientStop Color="#FF8A65" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#FF5722" Opacity="0.3" BlurRadius="8" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Stats_LongestStreak}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,14" Foreground="#FFFFFFCC"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="LongestStreakText" Text="0" FontSize="48"
                                       FontWeight="Bold" Foreground="White" />
                            <TextBlock Text="{DynamicResource Stats_Days}" FontSize="18"
                                       VerticalAlignment="Bottom" Margin="6,0,0,6"
                                       Foreground="#FFFFFFCC" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>

<UserControl x:Class="EasyMovie.Client.Views.StatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="900">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,24">

            <!-- 标题 -->
            <TextBlock Text="统计面板" FontSize="28" FontWeight="Bold"
                       Margin="0,0,0,20" />

            <!-- 概览卡片 -->
            <WrapPanel Margin="0,0,0,20">
                <Border Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="8" Width="150" Padding="16" Margin="0,0,12,12">
                    <StackPanel>
                        <TextBlock Text="总电影" FontSize="12"
                                   Foreground="{DynamicResource MaterialDesignHintForeground}" />
                        <TextBlock x:Name="TotalMoviesText" Text="0" FontSize="28"
                                   FontWeight="Bold" Foreground="#7C4DFF" />
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="8" Width="150" Padding="16" Margin="0,0,12,12">
                    <StackPanel>
                        <TextBlock Text="已看" FontSize="12"
                                   Foreground="{DynamicResource MaterialDesignHintForeground}" />
                        <TextBlock x:Name="WatchedText" Text="0" FontSize="28"
                                   FontWeight="Bold" Foreground="#4CAF50" />
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="8" Width="150" Padding="16" Margin="0,0,12,12">
                    <StackPanel>
                        <TextBlock Text="想看" FontSize="12"
                                   Foreground="{DynamicResource MaterialDesignHintForeground}" />
                        <TextBlock x:Name="WantWatchText" Text="0" FontSize="28"
                                   FontWeight="Bold" Foreground="#FF9800" />
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="8" Width="150" Padding="16" Margin="0,0,12,12">
                    <StackPanel>
                        <TextBlock Text="平均评分" FontSize="12"
                                   Foreground="{DynamicResource MaterialDesignHintForeground}" />
                        <TextBlock x:Name="AvgRatingText" Text="0.0" FontSize="28"
                                   FontWeight="Bold" Foreground="#E91E63" />
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="8" Width="150" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="收藏" FontSize="12"
                                   Foreground="{DynamicResource MaterialDesignHintForeground}" />
                        <TextBlock x:Name="FavoritesText" Text="0" FontSize="28"
                                   FontWeight="Bold" Foreground="#FFC107" />
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- 分类分布 -->
            <Border Background="{DynamicResource MaterialDesignCardBackground}"
                    CornerRadius="8" Padding="16" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="分类分布" FontSize="16" FontWeight="Bold" Margin="0,0,0,12" />
                    <ItemsControl x:Name="CategoryChart">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3" Height="26">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="50" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name}" FontSize="12"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding Name}" />
                                    <Border Grid.Column="1" Background="#E0E0E0" CornerRadius="4" Height="18" VerticalAlignment="Center">
                                        <Border Background="{Binding Color}" CornerRadius="4"
                                                HorizontalAlignment="Left"
                                                Width="{Binding BarWidth}" />
                                    </Border>
                                    <TextBlock Grid.Column="2" Text="{Binding CountText}" FontSize="12"
                                               VerticalAlignment="Center" HorizontalAlignment="Right"
                                               Foreground="{DynamicResource MaterialDesignHintForeground}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- 评分分布 -->
            <Border Background="{DynamicResource MaterialDesignCardBackground}"
                    CornerRadius="8" Padding="16" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="评分分布" FontSize="16" FontWeight="Bold" Margin="0,0,0,12" />
                    <ItemsControl x:Name="RatingChart">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3" Height="26">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="50" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Label}" FontSize="12"
                                               VerticalAlignment="Center" />
                                    <Border Grid.Column="1" Background="#E0E0E0" CornerRadius="4" Height="18" VerticalAlignment="Center">
                                        <Border Background="#7C4DFF" CornerRadius="4"
                                                HorizontalAlignment="Left"
                                                Width="{Binding BarWidth}" />
                                    </Border>
                                    <TextBlock Grid.Column="2" Text="{Binding CountText}" FontSize="12"
                                               VerticalAlignment="Center" HorizontalAlignment="Right"
                                               Foreground="{DynamicResource MaterialDesignHintForeground}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- 年度趋势 -->
            <Border Background="{DynamicResource MaterialDesignCardBackground}"
                    CornerRadius="8" Padding="16" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="年度趋势" FontSize="16" FontWeight="Bold" Margin="0,0,0,12" />
                    <ItemsControl x:Name="YearlyChart">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2" Height="22">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="40" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding YearText}" FontSize="11"
                                               VerticalAlignment="Center" />
                                    <Border Grid.Column="1" Background="#E0E0E0" CornerRadius="3" Height="14" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Background="#7C4DFF" CornerRadius="3"
                                                    HorizontalAlignment="Left"
                                                    Width="{Binding AddedWidth}" Height="14" />
                                            <Border Background="#4CAF50" CornerRadius="3"
                                                    HorizontalAlignment="Left"
                                                    Width="{Binding WatchedWidth}" Height="14" />
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Grid.Column="2" Text="{Binding YearSummary}" FontSize="10"
                                               VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Border Width="14" Height="14" Background="#7C4DFF" CornerRadius="3" Margin="0,0,6,0" />
                        <TextBlock Text="总数" FontSize="11" Margin="0,0,16,0" />
                        <Border Width="14" Height="14" Background="#4CAF50" CornerRadius="3" Margin="0,0,6,0" />
                        <TextBlock Text="已看" FontSize="11" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 月度观影 -->
            <Border Background="{DynamicResource MaterialDesignCardBackground}"
                    CornerRadius="8" Padding="16">
                <StackPanel>
                    <TextBlock Text="今年月度观影趋势" FontSize="16" FontWeight="Bold" Margin="0,0,0,12" />
                    <ItemsControl x:Name="MonthlyChart">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2" Height="22">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="30" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding MonthText}" FontSize="11"
                                               VerticalAlignment="Center" />
                                    <Border Grid.Column="1" Background="#E0E0E0" CornerRadius="3" Height="14" VerticalAlignment="Center">
                                        <Border Background="#4CAF50" CornerRadius="3"
                                                HorizontalAlignment="Left"
                                                Width="{Binding BarWidth}" Height="14" />
                                    </Border>
                                    <TextBlock Grid.Column="2" Text="{Binding CountText}" FontSize="11"
                                               VerticalAlignment="Center" HorizontalAlignment="Right"
                                               Foreground="{DynamicResource MaterialDesignHintForeground}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>

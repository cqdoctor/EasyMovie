<UserControl x:Class="EasyMovie.Client.Views.MovieListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:controls="clr-namespace:EasyMovie.Client.Controls"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">

    <Grid>
        <Grid.Resources>
            <Style TargetType="DataGridCell">
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="6,0" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Stretch" />
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
                <Setter Property="Focusable" Value="False" />
                <Setter Property="IsTabStop" Value="False" />
                <Setter Property="Background" Value="Transparent" />
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="CellTextBlock" TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Margin" Value="6,0" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>
            <Style x:Key="CompactExpander" TargetType="Expander" BasedOn="{StaticResource MaterialDesignExpander}">
                <Setter Property="Padding" Value="0,2,0,0" />
                <Setter Property="materialDesign:ExpanderAssist.HorizontalHeaderPadding" Value="0,4,0,4" />
            </Style>
            <Style TargetType="DataGridRow">
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
                <Setter Property="Background" Value="#01FFFFFF" />
                <Setter Property="Cursor" Value="Hand" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#0A000000" />
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
                        <Setter Property="Background" Value="#1A000000" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{DynamicResource MovieLib_Title}" FontSize="28" FontWeight="Bold"
                       VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="RecommendToggleBtn"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Click="RecommendToggle_Click"
                        ToolTip="{DynamicResource Tip_Recommend}"
                        Padding="8,4,8,4"
                        Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="StarShooting" Margin="0,0,4,0" />
                        <TextBlock Text="{DynamicResource MovieLib_Recommend}" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        Click="FetchAll_Click"
                        ToolTip="{DynamicResource Tip_FetchAll}"
                        Padding="8,4,8,4"
                        Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CloudDownload" Margin="0,0,4,0" />
                        <TextBlock Text="{DynamicResource MovieLib_FetchAll}" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        Click="ImportFolder_Click"
                        ToolTip="{DynamicResource Tip_ImportFolder}"
                        Padding="8,4,8,4"
                        Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FolderOpen" Margin="0,0,4,0" />
                        <TextBlock Text="{DynamicResource MovieLib_ImportFolder}" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        Click="OnlineSearch_Click"
                        ToolTip="{DynamicResource Tip_OnlineSearch}"
                        Padding="8,4,8,4"
                        Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CloudSearch" Margin="0,0,4,0" />
                        <TextBlock Text="{DynamicResource MovieLib_OnlineSearch}" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                        Click="AddMovie_Click"
                        ToolTip="{DynamicResource Tip_AddMovie}"
                        Width="40" Height="40">
                    <materialDesign:PackIcon Kind="PlusCircle" Width="24" Height="24" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- 搜索 & 筛选栏 -->
        <Border Grid.Row="1"
                Background="{DynamicResource MaterialDesignCardBackground}"
                CornerRadius="8" Padding="0,4,0,2" Margin="0,0,0,4">
            <StackPanel>
                <!-- 第一行：搜索 + 基本筛选 + 视图切换 -->
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- 搜索框 -->
                    <TextBox x:Name="SearchBox"
                             Grid.Column="0"
                             materialDesign:HintAssist.Hint="{DynamicResource MovieLib_SearchHint}"
                             Style="{StaticResource MaterialDesignTextBox}"
                             VerticalAlignment="Bottom"
                             TextChanged="SearchBox_TextChanged"
                             Margin="0,0,12,0" />

                    <!-- 分类筛选 -->
                    <ComboBox x:Name="CategoryFilter"
                              Grid.Column="1"
                              materialDesign:HintAssist.Hint="{DynamicResource MovieLib_Category}"
                              Style="{StaticResource MaterialDesignComboBox}"
                              VerticalAlignment="Bottom"
                              Width="120" Margin="0,0,8,0"
                              SelectionChanged="Filter_Changed" />

                    <!-- 观看状态筛选 -->
                    <ComboBox x:Name="StatusFilter"
                              Grid.Column="2"
                              materialDesign:HintAssist.Hint="{DynamicResource MovieLib_Status}"
                              Style="{StaticResource MaterialDesignComboBox}"
                              VerticalAlignment="Bottom"
                              Width="100" Margin="0,0,8,0"
                              SelectionChanged="Filter_Changed">
                        <ComboBoxItem Content="{DynamicResource MovieLib_All}" />
                        <ComboBoxItem Content="{DynamicResource MovieLib_WantToWatch}" Tag="WantToWatch" />
                        <ComboBoxItem Content="{DynamicResource MovieLib_Watching}" Tag="Watching" />
                        <ComboBoxItem Content="{DynamicResource MovieLib_Watched}" Tag="Watched" />
                    </ComboBox>

                    <!-- 年份筛选 -->
                    <ComboBox x:Name="YearFilter"
                              Grid.Column="3"
                              materialDesign:HintAssist.Hint="{DynamicResource MovieLib_Year}"
                              Style="{StaticResource MaterialDesignComboBox}"
                              VerticalAlignment="Bottom"
                              Width="100" Margin="0,0,8,0"
                              SelectionChanged="Filter_Changed" />

                    <!-- 排序 -->
                    <ComboBox x:Name="SortFilter"
                              Grid.Column="4"
                              materialDesign:HintAssist.Hint="{DynamicResource MovieLib_Sort}"
                              Style="{StaticResource MaterialDesignComboBox}"
                              VerticalAlignment="Bottom"
                              Width="110" Margin="0,0,8,0"
                              SelectionChanged="Filter_Changed">
                        <ComboBoxItem Content="{DynamicResource MovieLib_SortCreatedDesc}" Tag="createdat_desc" />
                        <ComboBoxItem Content="{DynamicResource MovieLib_SortCreatedAsc}" Tag="createdat_asc" />
                        <ComboBoxItem Content="{DynamicResource MovieLib_SortRatingDesc}" Tag="rating_desc" />
                        <ComboBoxItem Content="{DynamicResource MovieLib_SortRatingAsc}" Tag="rating_asc" />
                        <ComboBoxItem Content="{DynamicResource MovieLib_SortYearDesc}" Tag="year_desc" />
                        <ComboBoxItem Content="{DynamicResource MovieLib_SortYearAsc}" Tag="year_asc" />
                        <ComboBoxItem Content="{DynamicResource MovieLib_SortTitleAsc}" Tag="title_asc" />
                    </ComboBox>

                    <!-- 视图切换 -->
                    <StackPanel Grid.Column="5" Orientation="Horizontal">
                        <Button x:Name="TableViewBtn"
                                Style="{StaticResource MaterialDesignIconForegroundButton}"
                                Click="TableViewBtn_Click"
                                ToolTip="{DynamicResource MovieLib_ListView}"
                                Margin="0,0,2,0">
                            <materialDesign:PackIcon Kind="ViewList" Width="20" Height="20" />
                        </Button>
                        <Button x:Name="CardViewBtn"
                                Style="{StaticResource MaterialDesignIconForegroundButton}"
                                Click="CardViewBtn_Click"
                                ToolTip="{DynamicResource MovieLib_CardView}"
                                Margin="0,0,2,0">
                            <materialDesign:PackIcon Kind="ViewGrid" Width="20" Height="20" />
                        </Button>
                        <Button x:Name="PosterViewBtn"
                                Style="{StaticResource MaterialDesignIconForegroundButton}"
                                Click="PosterViewBtn_Click"
                                ToolTip="{DynamicResource MovieLib_PosterView}">
                            <materialDesign:PackIcon Kind="ImageMultiple" Width="20" Height="20" />
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- 高级筛选面板（默认折叠） -->
                <Expander x:Name="AdvancedFilterPanel"
                          IsExpanded="False"
                          Style="{StaticResource CompactExpander}"
                          Margin="0,0,0,0">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FilterVariant" Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center" />
                            <TextBlock Text="{DynamicResource MovieLib_AdvancedFilter}" FontSize="12" VerticalAlignment="Center" />
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel>
                    <!-- 范围筛选：标签一行 + 滑块一行 -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- 标签行 -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource MovieLib_YearRange}" FontSize="11" Foreground="{DynamicResource MaterialDesignHintForeground}" Margin="0,0,12,2" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{DynamicResource MovieLib_RatingRange}" FontSize="11" Foreground="{DynamicResource MaterialDesignHintForeground}" Margin="0,0,12,2" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="{DynamicResource MovieLib_Runtime}" FontSize="11" Foreground="{DynamicResource MaterialDesignHintForeground}" Margin="0,0,12,2" />

                        <!-- 滑块行 -->
                        <controls:RangeSlider Grid.Row="1" Grid.Column="0" x:Name="YearRangeSlider"
                                              TickFrequency="10" IsSnapToTickEnabled="True"
                                              Margin="0,0,12,0"
                                              RangeChanged="RangeSlider_RangeChanged" />
                        <controls:RangeSlider Grid.Row="1" Grid.Column="1" x:Name="RatingRangeSlider"
                                              IsSnapToTickEnabled="True"
                                              Margin="0,0,12,0"
                                              RangeChanged="RangeSlider_RangeChanged" />
                        <controls:RangeSlider Grid.Row="1" Grid.Column="2" x:Name="RuntimeRangeSlider"
                                              TickFrequency="30" IsSnapToTickEnabled="True"
                                              Margin="0,0,12,0"
                                              RangeChanged="RangeSlider_RangeChanged" />
                    </Grid>

                    <!-- 多选行：国家/语言/导演 -->
                    <UniformGrid Columns="3" Margin="0,4,0,0">
                        <!-- 国家（多选） -->
                        <StackPanel Margin="0,0,12,4">
                            <TextBlock Text="{DynamicResource MovieLib_Country}" FontSize="11" Foreground="{DynamicResource MaterialDesignHintForeground}" Margin="0,0,0,2" />
                            <ListBox x:Name="CountryFilter"
                                     SelectionMode="Multiple"
                                     Height="80"
                                     FontSize="12"
                                     Style="{StaticResource MaterialDesignFilterChipListBox}" />
                        </StackPanel>

                        <!-- 语言（多选） -->
                        <StackPanel Margin="0,0,12,4">
                            <TextBlock Text="{DynamicResource MovieLib_Language}" FontSize="11" Foreground="{DynamicResource MaterialDesignHintForeground}" Margin="0,0,0,2" />
                            <ListBox x:Name="LanguageFilter"
                                     SelectionMode="Multiple"
                                     Height="80"
                                     FontSize="12"
                                     Style="{StaticResource MaterialDesignFilterChipListBox}" />
                        </StackPanel>

                        <!-- 导演（多选） -->
                        <StackPanel Margin="0,0,12,4">
                            <TextBlock Text="{DynamicResource MovieLib_Director}" FontSize="11" Foreground="{DynamicResource MaterialDesignHintForeground}" Margin="0,0,0,2" />
                            <ListBox x:Name="DirectorFilter"
                                     SelectionMode="Multiple"
                                     Height="80"
                                     FontSize="12"
                                     Style="{StaticResource MaterialDesignFilterChipListBox}" />
                        </StackPanel>
                    </UniformGrid>

                    <!-- 操作按钮 -->
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0" HorizontalAlignment="Left">
                        <Button Content="{DynamicResource MovieLib_ApplyFilter}" Style="{StaticResource MaterialDesignRaisedButton}"
                                Click="ApplyAdvancedFilter_Click" Margin="0,0,8,0" />
                        <Button Content="{DynamicResource MovieLib_Reset}" Style="{StaticResource MaterialDesignOutlinedButton}"
                                Click="ResetAdvancedFilter_Click" Margin="0,0,8,0" />
                        <Button Content="{DynamicResource MovieLib_SaveFilter}" Style="{StaticResource MaterialDesignOutlinedButton}"
                                Click="SaveFilter_Click" ToolTip="{DynamicResource Tip_SaveFilter}" Margin="0,0,8,0" />
                        <ComboBox x:Name="SavedFilterCombo"
                                  materialDesign:HintAssist.Hint="{DynamicResource MovieLib_LoadFilter}"
                                  Style="{StaticResource MaterialDesignComboBox}"
                                  FontSize="12" Width="140"
                                  SelectionChanged="SavedFilterCombo_SelectionChanged" />
                        <Button x:Name="DeleteFilterBtn" Content="✕" Style="{StaticResource MaterialDesignIconButton}"
                                Click="DeleteFilter_Click" ToolTip="{DynamicResource MovieLib_DeleteFilter}"
                                Width="28" Height="28" FontSize="12" Margin="4,0,0,0" Visibility="Collapsed" />
                    </StackPanel>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </Border>

        <!-- 电影列表 / 卡片视图 -->
        <Grid Grid.Row="2" Opacity="0.92">
            <!-- 列表视图 -->
            <DataGrid x:Name="MovieDataGrid"
                      Visibility="Visible"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow"
                      MinRowHeight="36"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True"
                      VerticalContentAlignment="Stretch"
                      MouseDoubleClick="MovieDataGrid_MouseDoubleClick"
                      PreviewMouseLeftButtonDown="MovieDataGrid_PreviewMouseLeftButtonDown"
                      SelectionChanged="MovieDataGrid_SelectionChanged"
                      Style="{StaticResource MaterialDesignDataGrid}" GridLinesVisibility="None"
                      Background="{DynamicResource MaterialDesignBackground}"
                      HeadersVisibility="Column"
                      BorderThickness="0"
                      ClipToBounds="True"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{DynamicResource MovieLib_ColTitle}" Binding="{Binding Title}"
                                        Width="180" ElementStyle="{StaticResource CellTextBlock}" />
                    <DataGridTextColumn Header="{DynamicResource MovieLib_ColYear}" Binding="{Binding Year}" Width="70" ElementStyle="{StaticResource CellTextBlock}" />
                    <DataGridTextColumn Header="{DynamicResource MovieLib_ColDirector}" Binding="{Binding Director}" Width="100" ElementStyle="{StaticResource CellTextBlock}" />
                    <DataGridTextColumn Header="{DynamicResource MovieLib_ColCategory}" Binding="{Binding Category.Name}" Width="80" ElementStyle="{StaticResource CellTextBlock}" />
                    <DataGridTemplateColumn Header="{DynamicResource MovieLib_ColRating}" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Rating, StringFormat='⭐{0}'}"
                                               Visibility="{Binding Rating, Converter={StaticResource NullToVisibilityConverter}}" />
                                    <TextBlock Text="-"
                                               Visibility="{Binding Rating, Converter={StaticResource NullToCollapsedConverter}}"
                                               Foreground="{DynamicResource MaterialDesignHintForeground}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="{DynamicResource MovieLib_ColStatus}" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding WatchStatus, Converter={StaticResource WatchStatusConverter}}"
                                           Foreground="{DynamicResource MaterialDesignBody}" VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="{DynamicResource MovieLib_ColFavorite}" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding IsFavorite, Converter={StaticResource BoolToStarConverter}}"
                                           FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="{DynamicResource MovieLib_ColFile}" Width="40">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FilePath, Converter={StaticResource FilePathIconConverter}}"
                                           FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="{DynamicResource MovieLib_ColAction}" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                            Click="PlayMovie_Click" Tag="{Binding Id}"
                                            ToolTip="{DynamicResource Tip_Play}">
                                        <materialDesign:PackIcon Kind="Play" Width="18" Height="18" />
                                    </Button>
                                    <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                            Click="FetchInfo_Click" Tag="{Binding Id}"
                                            ToolTip="{DynamicResource Tip_FetchInfo}">
                                        <materialDesign:PackIcon Kind="CloudDownload" Width="18" Height="18" />
                                    </Button>
                                    <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                            Click="EditMovie_Click" Tag="{Binding Id}"
                                            ToolTip="{DynamicResource Tip_Edit}">
                                        <materialDesign:PackIcon Kind="Edit" Width="18" Height="18" />
                                    </Button>
                                    <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                            Click="DeleteMovie_Click" Tag="{Binding Id}"
                                            ToolTip="{DynamicResource Tip_Delete}">
                                        <materialDesign:PackIcon Kind="Delete" Width="18" Height="18" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- 卡片视图 -->
            <ScrollViewer x:Name="CardScrollViewer" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto">
                <WrapPanel x:Name="CardPanel" />
            </ScrollViewer>

            <!-- 海报墙视图 -->
            <ListBox x:Name="PosterWall"
                     Visibility="Collapsed"
                     SelectionMode="Extended"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     BorderThickness="0"
                     Background="Transparent"
                     MouseDoubleClick="PosterWall_MouseDoubleClick"
                     SelectionChanged="PosterWall_SelectionChanged">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="4" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="ItemBorder"
                                            Background="Transparent"
                                            CornerRadius="8"
                                            Padding="0">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Opacity" Value="0.85" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}" />
                                            <Setter TargetName="ItemBorder" Property="BorderThickness" Value="3" />
                                            <Setter TargetName="ItemBorder" Property="CornerRadius" Value="8" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="185" Height="278" Cursor="Hand">
                            <!-- 封面 -->
                            <Border CornerRadius="8" ClipToBounds="True"
                                    Background="{DynamicResource MaterialDesignDivider}">
                                <Grid>
                                    <Image Source="{Binding PosterData, Converter={StaticResource PosterImageConverter}}"
                                           Stretch="UniformToFill"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                    <!-- 无封面占位 -->
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                                Visibility="{Binding PosterData, Converter={StaticResource NullToVisibilityConverter}}">
                                        <materialDesign:PackIcon Kind="MovieOpen" Width="48" Height="48"
                                                                 HorizontalAlignment="Center"
                                                                 Foreground="{DynamicResource MaterialDesignHintForeground}" />
                                        <TextBlock Text="{Binding Title}" FontSize="12"
                                                   TextWrapping="Wrap" TextAlignment="Center"
                                                   MaxHeight="60" Margin="6,6,6,0"
                                                   Foreground="{DynamicResource MaterialDesignHintForeground}" />
                                    </StackPanel>
                                    <!-- 底部渐变信息条 -->
                                    <Border VerticalAlignment="Bottom" CornerRadius="0,0,8,8" Padding="8,6">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Offset="0" Color="#00000000" />
                                                <GradientStop Offset="0.3" Color="#99000000" />
                                                <GradientStop Offset="1" Color="#DD000000" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="White" TextTrimming="CharacterEllipsis" />
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock Text="{Binding Year}" FontSize="11" Foreground="#BBFFFFFF" Margin="0,0,6,0" />
                                                <TextBlock Text="{Binding Rating, StringFormat='⭐{0}'}"
                                                           FontSize="11" Foreground="#FFD700"
                                                           Visibility="{Binding Rating, Converter={StaticResource NullToCollapsedConverter}}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- 空状态 -->
            <TextBlock x:Name="EmptyLabel"
                       Text="{DynamicResource MovieLib_Empty}"
                       FontSize="16"
                       Foreground="{DynamicResource MaterialDesignHintForeground}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="Collapsed" />
        </Grid>

        <!-- 批量操作面板 -->
        <Border x:Name="BatchEditPanel" Grid.Row="3" Visibility="Collapsed"
                Background="{DynamicResource MaterialDesignCardBackground}"
                CornerRadius="8" Padding="12,8" Margin="0,8,0,0">
            <StackPanel>
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="PlaylistEdit" Width="20" Height="20" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock x:Name="BatchCountText" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                    <Button Style="{StaticResource MaterialDesignIconButton}" HorizontalAlignment="Right"
                            Click="BatchPanelClose_Click" Width="28" Height="28">
                        <materialDesign:PackIcon Kind="Close" Width="16" Height="16" />
                    </Button>
                </Grid>
                <UniformGrid Columns="4" Margin="0,8,0,0">
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="{DynamicResource MovieLib_BatchCategory}" FontSize="11" Foreground="{DynamicResource MaterialDesignHintForeground}" Margin="0,0,0,2" />
                        <ComboBox x:Name="BatchCategoryCombo" Style="{StaticResource MaterialDesignComboBox}" FontSize="12" />
                    </StackPanel>
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="{DynamicResource MovieLib_BatchStatus}" FontSize="11" Foreground="{DynamicResource MaterialDesignHintForeground}" Margin="0,0,0,2" />
                        <ComboBox x:Name="BatchStatusCombo" Style="{StaticResource MaterialDesignComboBox}" FontSize="12">
                            <ComboBoxItem Content="{DynamicResource MovieLib_BatchNoChange}" Tag="" />
                            <ComboBoxItem Content="{DynamicResource MovieLib_WantToWatch}" Tag="WantToWatch" />
                            <ComboBoxItem Content="{DynamicResource MovieLib_Watching}" Tag="Watching" />
                            <ComboBoxItem Content="{DynamicResource MovieLib_Watched}" Tag="Watched" />
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="{DynamicResource MovieLib_BatchRating}" FontSize="11" Foreground="{DynamicResource MaterialDesignHintForeground}" Margin="0,0,0,2" />
                        <ComboBox x:Name="BatchRatingCombo" Style="{StaticResource MaterialDesignComboBox}" FontSize="12">
                            <ComboBoxItem Content="{DynamicResource MovieLib_BatchNoChange}" Tag="" />
                            <ComboBoxItem Content="1" Tag="1" />
                            <ComboBoxItem Content="2" Tag="2" />
                            <ComboBoxItem Content="3" Tag="3" />
                            <ComboBoxItem Content="4" Tag="4" />
                            <ComboBoxItem Content="5" Tag="5" />
                            <ComboBoxItem Content="6" Tag="6" />
                            <ComboBoxItem Content="7" Tag="7" />
                            <ComboBoxItem Content="8" Tag="8" />
                            <ComboBoxItem Content="9" Tag="9" />
                            <ComboBoxItem Content="10" Tag="10" />
                        </ComboBox>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource MovieLib_BatchFavorite}" FontSize="11" Foreground="{DynamicResource MaterialDesignHintForeground}" Margin="0,0,0,2" />
                        <ComboBox x:Name="BatchFavoriteCombo" Style="{StaticResource MaterialDesignComboBox}" FontSize="12">
                            <ComboBoxItem Content="{DynamicResource MovieLib_BatchNoChange}" Tag="" />
                            <ComboBoxItem Content="{DynamicResource MovieLib_BatchFavSet}" Tag="true" />
                            <ComboBoxItem Content="{DynamicResource MovieLib_BatchFavUnset}" Tag="false" />
                        </ComboBox>
                    </StackPanel>
                </UniformGrid>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="{DynamicResource MovieLib_BatchApply}" Style="{StaticResource MaterialDesignRaisedButton}"
                            Click="BatchApply_Click" Margin="0,0,8,0" />
                    <Button Content="{DynamicResource MovieLib_BatchDelete}" Style="{StaticResource MaterialDesignOutlinedButton}"
                            Click="BatchDelete_Click" Margin="0,0,8,0" />
                    <Button Content="{DynamicResource MovieLib_BatchSelectAll}" Style="{StaticResource MaterialDesignFlatButton}"
                            Click="BatchSelectAll_Click" Margin="0,0,8,0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 分页 -->
        <Border x:Name="PaginationBorder" Grid.Row="4" Margin="0,12,0,0">
            <Grid>
                <TextBlock x:Name="PageInfo" VerticalAlignment="Center"
                           Foreground="{DynamicResource MaterialDesignHintForeground}" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{DynamicResource MovieLib_PrevPage}" Style="{StaticResource MaterialDesignFlatButton}"
                            x:Name="PrevPageBtn" Click="PrevPage_Click" />
                    <Button Content="{DynamicResource MovieLib_NextPage}" Style="{StaticResource MaterialDesignFlatButton}"
                            x:Name="NextPageBtn" Click="NextPage_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

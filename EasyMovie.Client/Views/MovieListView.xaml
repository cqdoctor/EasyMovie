<UserControl x:Class="EasyMovie.Client.Views.MovieListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">

    <Grid>
        <Grid.Resources>
            <Style TargetType="DataGridCell">
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="6,0" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
                <Setter Property="Focusable" Value="False" />
                <Setter Property="IsTabStop" Value="False" />
                <Setter Property="Background" Value="#01FFFFFF" />
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="CellTextBlock" TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Margin" Value="6,0" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>
            <Style TargetType="DataGridRow">
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
                <Setter Property="Background" Value="#01FFFFFF" />
                <Setter Property="Cursor" Value="Hand" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#0A000000" />
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
                        <Setter Property="Background" Value="#1A000000" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="🎬 电影库" FontSize="28" FontWeight="Bold"
                       VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        Click="FetchAll_Click"
                        ToolTip="批量获取列表所有电影信息"
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CloudDownload" Margin="0,0,4,0" />
                        <TextBlock Text="全部获取" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="ImportFolder_Click"
                        ToolTip="导入视频文件夹，自动获取豆瓣信息"
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FolderOpen" Margin="0,0,6,0" />
                        <TextBlock Text="导入文件夹" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="OnlineSearch_Click"
                        ToolTip="在线搜索添加 (豆瓣/TMDB)"
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CloudSearch" Margin="0,0,6,0" />
                        <TextBlock Text="在线搜索" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                        Click="AddMovie_Click"
                        ToolTip="手动添加电影"
                        Width="40" Height="40">
                    <materialDesign:PackIcon Kind="PlusCircle" Width="24" Height="24" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- 搜索 & 筛选栏 -->
        <Border Grid.Row="1"
                Background="{DynamicResource MaterialDesignCardBackground}"
                CornerRadius="8" Padding="16,12,16,8" Margin="0,0,0,4">
            <StackPanel>
                <!-- 第一行：搜索 + 基本筛选 + 视图切换 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- 搜索框 -->
                    <TextBox x:Name="SearchBox"
                             Grid.Column="0"
                             materialDesign:HintAssist.Hint="搜索片名、导演、演员..."
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             TextChanged="SearchBox_TextChanged"
                             Margin="0,0,12,0" />

                    <!-- 分类筛选 -->
                    <ComboBox x:Name="CategoryFilter"
                              Grid.Column="1"
                              materialDesign:HintAssist.Hint="分类"
                              Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                              Width="120" Margin="0,0,8,0"
                              SelectionChanged="Filter_Changed" />

                    <!-- 观看状态筛选 -->
                    <ComboBox x:Name="StatusFilter"
                              Grid.Column="2"
                              materialDesign:HintAssist.Hint="状态"
                              Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                              Width="100" Margin="0,0,8,0"
                              SelectionChanged="Filter_Changed">
                        <ComboBoxItem Content="全部" />
                        <ComboBoxItem Content="想看" Tag="WantToWatch" />
                        <ComboBoxItem Content="在看" Tag="Watching" />
                        <ComboBoxItem Content="已看" Tag="Watched" />
                    </ComboBox>

                    <!-- 年份筛选 -->
                    <ComboBox x:Name="YearFilter"
                              Grid.Column="3"
                              materialDesign:HintAssist.Hint="年份"
                              Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                              Width="100" Margin="0,0,8,0"
                              SelectionChanged="Filter_Changed" />

                    <!-- 排序 -->
                    <ComboBox x:Name="SortFilter"
                              Grid.Column="4"
                              materialDesign:HintAssist.Hint="排序"
                              Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                              Width="110" Margin="0,0,8,0"
                              SelectionChanged="Filter_Changed">
                        <ComboBoxItem Content="添加时间↓" Tag="createdat_desc" />
                        <ComboBoxItem Content="添加时间↑" Tag="createdat_asc" />
                        <ComboBoxItem Content="评分↓" Tag="rating_desc" />
                        <ComboBoxItem Content="评分↑" Tag="rating_asc" />
                        <ComboBoxItem Content="年份↓" Tag="year_desc" />
                        <ComboBoxItem Content="年份↑" Tag="year_asc" />
                        <ComboBoxItem Content="片名 A-Z" Tag="title_asc" />
                    </ComboBox>

                    <!-- 高级筛选展开按钮 -->
                    <ToggleButton x:Name="AdvancedFilterToggle"
                                  Grid.Column="5"
                                  Style="{StaticResource MaterialDesignActionToggleButton}"
                                  ToolTip="高级筛选"
                                  Margin="0,0,4,0"
                                  Checked="AdvancedFilterToggle_Changed"
                                  Unchecked="AdvancedFilterToggle_Changed">
                        <materialDesign:PackIcon Kind="FilterVariant" />
                    </ToggleButton>

                    <!-- 视图切换 -->
                    <StackPanel Grid.Column="6" Orientation="Horizontal">
                        <Button x:Name="TableViewBtn"
                                Style="{StaticResource MaterialDesignIconForegroundButton}"
                                Click="TableViewBtn_Click"
                                ToolTip="列表视图">
                            <materialDesign:PackIcon Kind="ViewList" />
                        </Button>
                        <Button x:Name="CardViewBtn"
                                Style="{StaticResource MaterialDesignIconForegroundButton}"
                                Click="CardViewBtn_Click"
                                ToolTip="卡片视图">
                            <materialDesign:PackIcon Kind="ViewGrid" />
                        </Button>
                        <Button x:Name="PosterViewBtn"
                                Style="{StaticResource MaterialDesignIconForegroundButton}"
                                Click="PosterViewBtn_Click"
                                ToolTip="海报墙">
                            <materialDesign:PackIcon Kind="ImageMultiple" />
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- 高级筛选面板（默认折叠） -->
                <Expander x:Name="AdvancedFilterPanel"
                          IsExpanded="False"
                          Margin="0,8,0,0"
                          Header="">
                    <UniformGrid Columns="4" Margin="0,4,0,0">
                        <!-- 年份范围 -->
                        <StackPanel Margin="0,0,12,8">
                            <TextBlock Text="年份范围" FontSize="12" Foreground="{DynamicResource MaterialDesignHintForeground}" Margin="0,0,0,4" />
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="YearFromBox" Width="60" materialDesign:HintAssist.Hint="从" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,4,0" />
                                <TextBlock Text="-" VerticalAlignment="Center" Margin="0,0,4,0" />
                                <TextBox x:Name="YearToBox" Width="60" materialDesign:HintAssist.Hint="到" Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                            </StackPanel>
                        </StackPanel>

                        <!-- 评分范围 -->
                        <StackPanel Margin="0,0,12,8">
                            <TextBlock Text="评分范围" FontSize="12" Foreground="{DynamicResource MaterialDesignHintForeground}" Margin="0,0,0,4" />
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="RatingMinBox" Width="60" materialDesign:HintAssist.Hint="最低" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,4,0" />
                                <TextBlock Text="-" VerticalAlignment="Center" Margin="0,0,4,0" />
                                <TextBox x:Name="RatingMaxBox" Width="60" materialDesign:HintAssist.Hint="最高" Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                            </StackPanel>
                        </StackPanel>

                        <!-- 国家 -->
                        <StackPanel Margin="0,0,12,8">
                            <TextBlock Text="国家/地区" FontSize="12" Foreground="{DynamicResource MaterialDesignHintForeground}" Margin="0,0,0,4" />
                            <ComboBox x:Name="CountryFilter"
                                      materialDesign:HintAssist.Hint="全部国家"
                                      Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                      Width="140" />
                        </StackPanel>

                        <!-- 语言 -->
                        <StackPanel Margin="0,0,12,8">
                            <TextBlock Text="语言" FontSize="12" Foreground="{DynamicResource MaterialDesignHintForeground}" Margin="0,0,0,4" />
                            <ComboBox x:Name="LanguageFilter"
                                      materialDesign:HintAssist.Hint="全部语言"
                                      Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                      Width="140" />
                        </StackPanel>

                        <!-- 片长范围 -->
                        <StackPanel Margin="0,0,12,8">
                            <TextBlock Text="片长(分钟)" FontSize="12" Foreground="{DynamicResource MaterialDesignHintForeground}" Margin="0,0,0,4" />
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="RuntimeMinBox" Width="60" materialDesign:HintAssist.Hint="最短" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,4,0" />
                                <TextBlock Text="-" VerticalAlignment="Center" Margin="0,0,4,0" />
                                <TextBox x:Name="RuntimeMaxBox" Width="60" materialDesign:HintAssist.Hint="最长" Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                            </StackPanel>
                        </StackPanel>

                        <!-- 导演 -->
                        <StackPanel Margin="0,0,12,8">
                            <TextBlock Text="导演" FontSize="12" Foreground="{DynamicResource MaterialDesignHintForeground}" Margin="0,0,0,4" />
                            <ComboBox x:Name="DirectorFilter"
                                      materialDesign:HintAssist.Hint="全部导演"
                                      Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                      Width="140"
                                      IsEditable="True" />
                        </StackPanel>

                        <!-- 操作按钮 -->
                        <StackPanel Margin="0,0,12,8" VerticalAlignment="Bottom" Orientation="Horizontal">
                            <Button Content="应用筛选" Style="{StaticResource MaterialDesignRaisedButton}"
                                    Click="ApplyAdvancedFilter_Click" Margin="0,0,8,0" />
                            <Button Content="重置" Style="{StaticResource MaterialDesignFlatButton}"
                                    Click="ResetAdvancedFilter_Click" Margin="0,0,8,0" />
                            <Button Content="保存筛选" Style="{StaticResource MaterialDesignFlatButton}"
                                    Click="SaveFilter_Click" ToolTip="保存当前筛选条件" />
                        </StackPanel>
                    </UniformGrid>
                </Expander>
            </StackPanel>
        </Border>

        <!-- 电影列表 / 卡片视图 -->
        <Grid Grid.Row="2" Opacity="0.92">
            <!-- 列表视图 -->
            <DataGrid x:Name="MovieDataGrid"
                      Visibility="Visible"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      RowHeight="52"
                      VerticalContentAlignment="Center"
                      MouseDoubleClick="MovieDataGrid_MouseDoubleClick"
                      PreviewMouseLeftButtonDown="MovieDataGrid_PreviewMouseLeftButtonDown"
                      SelectionChanged="MovieDataGrid_SelectionChanged"
                      Style="{StaticResource MaterialDesignDataGrid}" GridLinesVisibility="None">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="片名" Binding="{Binding Title}"
                                        Width="180" ElementStyle="{StaticResource CellTextBlock}" />
                    <DataGridTextColumn Header="年份" Binding="{Binding Year}" Width="70" ElementStyle="{StaticResource CellTextBlock}" />
                    <DataGridTextColumn Header="导演" Binding="{Binding Director}" Width="100" ElementStyle="{StaticResource CellTextBlock}" />
                    <DataGridTextColumn Header="分类" Binding="{Binding Category.Name}" Width="80" ElementStyle="{StaticResource CellTextBlock}" />
                    <DataGridTemplateColumn Header="评分" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Rating, StringFormat='⭐{0}'}"
                                               Visibility="{Binding Rating, Converter={StaticResource NullToVisibilityConverter}}" />
                                    <TextBlock Text="-"
                                               Visibility="{Binding Rating, Converter={StaticResource NullToCollapsedConverter}}"
                                               Foreground="{DynamicResource MaterialDesignHintForeground}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="状态" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding WatchStatus, Converter={StaticResource WatchStatusConverter}}"
                                           Foreground="{DynamicResource MaterialDesignBody}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="收藏" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding IsFavorite, Converter={StaticResource BoolToStarConverter}}"
                                           FontSize="16" HorizontalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="文件" Width="40">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FilePath, Converter={StaticResource FilePathIconConverter}}"
                                           FontSize="14" HorizontalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="操作" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                            Click="PlayMovie_Click" Tag="{Binding Id}"
                                            ToolTip="播放">
                                        <materialDesign:PackIcon Kind="Play" Width="18" Height="18" />
                                    </Button>
                                    <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                            Click="FetchInfo_Click" Tag="{Binding Id}"
                                            ToolTip="获取电影信息">
                                        <materialDesign:PackIcon Kind="CloudDownload" Width="18" Height="18" />
                                    </Button>
                                    <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                            Click="EditMovie_Click" Tag="{Binding Id}"
                                            ToolTip="编辑">
                                        <materialDesign:PackIcon Kind="Edit" Width="18" Height="18" />
                                    </Button>
                                    <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                            Click="DeleteMovie_Click" Tag="{Binding Id}"
                                            ToolTip="删除">
                                        <materialDesign:PackIcon Kind="Delete" Width="18" Height="18" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- 卡片视图 -->
            <ScrollViewer x:Name="CardScrollViewer" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto">
                <WrapPanel x:Name="CardPanel" />
            </ScrollViewer>

            <!-- 海报墙视图 -->
            <ListBox x:Name="PosterWall"
                     Visibility="Collapsed"
                     SelectionMode="Single"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     BorderThickness="0"
                     Background="Transparent"
                     MouseDoubleClick="PosterWall_MouseDoubleClick"
                     SelectionChanged="PosterWall_SelectionChanged">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="4" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="ItemBorder"
                                            Background="Transparent"
                                            CornerRadius="8"
                                            Padding="0">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Opacity" Value="0.85" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}" />
                                            <Setter TargetName="ItemBorder" Property="BorderThickness" Value="3" />
                                            <Setter TargetName="ItemBorder" Property="CornerRadius" Value="8" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="185" Height="278" Cursor="Hand">
                            <!-- 封面 -->
                            <Border CornerRadius="8" ClipToBounds="True"
                                    Background="{DynamicResource MaterialDesignDivider}">
                                <Grid>
                                    <Image Source="{Binding PosterData, Converter={StaticResource PosterImageConverter}}"
                                           Stretch="UniformToFill"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                    <!-- 无封面占位 -->
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                                Visibility="{Binding PosterData, Converter={StaticResource NullToVisibilityConverter}}">
                                        <materialDesign:PackIcon Kind="MovieOpen" Width="48" Height="48"
                                                                 HorizontalAlignment="Center"
                                                                 Foreground="{DynamicResource MaterialDesignHintForeground}" />
                                        <TextBlock Text="{Binding Title}" FontSize="12"
                                                   TextWrapping="Wrap" TextAlignment="Center"
                                                   MaxHeight="60" Margin="6,6,6,0"
                                                   Foreground="{DynamicResource MaterialDesignHintForeground}" />
                                    </StackPanel>
                                    <!-- 底部渐变信息条 -->
                                    <Border VerticalAlignment="Bottom" CornerRadius="0,0,8,8" Padding="8,6">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Offset="0" Color="#00000000" />
                                                <GradientStop Offset="0.3" Color="#99000000" />
                                                <GradientStop Offset="1" Color="#DD000000" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="White" TextTrimming="CharacterEllipsis" />
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock Text="{Binding Year}" FontSize="11" Foreground="#BBFFFFFF" Margin="0,0,6,0" />
                                                <TextBlock Text="{Binding Rating, StringFormat='⭐{0}'}"
                                                           FontSize="11" Foreground="#FFD700"
                                                           Visibility="{Binding Rating, Converter={StaticResource NullToCollapsedConverter}}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- 空状态 -->
            <TextBlock x:Name="EmptyLabel"
                       Text="还没有电影，点击右上角 + 添加第一部吧 🎬"
                       FontSize="16"
                       Foreground="{DynamicResource MaterialDesignHintForeground}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="Collapsed" />
        </Grid>

        <!-- 分页 -->
        <Border Grid.Row="3" Margin="0,12,0,0">
            <Grid>
                <TextBlock x:Name="PageInfo" VerticalAlignment="Center"
                           Foreground="{DynamicResource MaterialDesignHintForeground}" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="上一页" Style="{StaticResource MaterialDesignFlatButton}"
                            x:Name="PrevPageBtn" Click="PrevPage_Click" />
                    <Button Content="下一页" Style="{StaticResource MaterialDesignFlatButton}"
                            x:Name="NextPageBtn" Click="NextPage_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

<UserControl x:Class="EasyMovie.Client.Views.MovieRelationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" Margin="16,16,16,0" Background="{DynamicResource MaterialDesignCardBackground}"
                CornerRadius="8" Padding="16,10">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="Graph" Width="22" Height="22"
                                             Foreground="#7C4DFF" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="{DynamicResource Relation_Title}" FontSize="18" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,16,0" />
                    <TextBlock x:Name="SummaryText" FontSize="12" Foreground="#89898989"
                               VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <CheckBox x:Name="ShowDirectorLinks" Content="{DynamicResource Relation_DirectorLink}"
                              IsChecked="True" Margin="0,0,12,0"
                              Checked="Filter_Changed" Unchecked="Filter_Changed" />
                    <CheckBox x:Name="ShowActorLinks" Content="{DynamicResource Relation_ActorLink}"
                              IsChecked="True" Margin="0,0,12,0"
                              Checked="Filter_Changed" Unchecked="Filter_Changed" />
                    <CheckBox x:Name="ShowGenreLinks" Content="{DynamicResource Relation_GenreLink}"
                              Margin="0,0,12,0"
                              Checked="Filter_Changed" Unchecked="Filter_Changed" />
                    <CheckBox x:Name="ShowCountryLinks" Content="{DynamicResource Relation_CountryLink}"
                              Margin="0,0,12,0"
                              Checked="Filter_Changed" Unchecked="Filter_Changed" />
                    <CheckBox x:Name="ShowDecadeLinks" Content="{DynamicResource Relation_DecadeLink}"
                              Margin="0,0,12,0"
                              Checked="Filter_Changed" Unchecked="Filter_Changed" />
                    <ComboBox x:Name="MinLinksCombo" Width="100" Margin="0,0,8,0"
                              SelectionChanged="Filter_Changed">
                        <ComboBoxItem Content="{DynamicResource Relation_AllNodes}" Tag="0" />
                        <ComboBoxItem Content="2+" Tag="2" IsSelected="True" />
                        <ComboBoxItem Content="3+" Tag="3" />
                        <ComboBoxItem Content="5+" Tag="5" />
                    </ComboBox>
                    <Button x:Name="RefreshBtn" Click="Refresh_Click"
                            Style="{StaticResource MaterialDesignFlatButton}" Padding="8,4">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16" Margin="0,0,4,0" />
                            <TextBlock Text="{DynamicResource Relation_Refresh}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 关系图区域 -->
        <Border Grid.Row="1" Margin="16,8,16,16" Background="{DynamicResource MaterialDesignCardBackground}"
                CornerRadius="8" ClipToBounds="True">
            <Grid x:Name="GraphContainer">
                <Canvas x:Name="GraphCanvas"
                        Background="Transparent"
                        MouseLeftButtonDown="Canvas_MouseDown"
                        MouseLeftButtonUp="Canvas_MouseUp"
                        MouseMove="Canvas_MouseMove"
                        MouseWheel="Canvas_MouseWheel">
                    <Canvas.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="CanvasScale" ScaleX="1" ScaleY="1"
                                            CenterX="0" CenterY="0" />
                            <TranslateTransform x:Name="CanvasTranslate" X="0" Y="0" />
                        </TransformGroup>
                    </Canvas.RenderTransform>
                </Canvas>

                <!-- 图例 -->
                <Border HorizontalAlignment="Left" VerticalAlignment="Bottom"
                        Margin="12" Background="#C0303030" CornerRadius="6" Padding="10,8">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Relation_Legend}" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#DDDDDD" Margin="0,0,0,6" />
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Rectangle Width="24" Height="3" Fill="#7C4DFF" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="{DynamicResource Relation_DirectorLink}" FontSize="10" Foreground="#BBBBBB" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Rectangle Width="24" Height="3" Fill="#26A69A" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="{DynamicResource Relation_ActorLink}" FontSize="10" Foreground="#BBBBBB" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Rectangle Width="24" Height="3" Fill="#FF9800" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="{DynamicResource Relation_GenreLink}" FontSize="10" Foreground="#BBBBBB" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Rectangle Width="24" Height="3" Fill="#2196F3" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="{DynamicResource Relation_CountryLink}" FontSize="10" Foreground="#BBBBBB" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Rectangle Width="24" Height="3" Fill="#009688" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="{DynamicResource Relation_DecadeLink}" FontSize="10" Foreground="#BBBBBB" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Rectangle Width="24" Height="3" Fill="#9C27B0" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="{DynamicResource Relation_MultiLink}" FontSize="10" Foreground="#BBBBBB" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 缩放提示 -->
                <Border HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        Margin="12" Background="#80303030" CornerRadius="4" Padding="6,3">
                    <TextBlock x:Name="ZoomText" Text="100%" FontSize="10" Foreground="#999999" />
                </Border>
            </Grid>
        </Border>

        <!-- 悬浮提示 -->
        <Border x:Name="TooltipBorder" Grid.Row="1" Visibility="Collapsed"
                Background="#E0303030" CornerRadius="6" Padding="10,6"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                IsHitTestVisible="False">
            <StackPanel>
                <TextBlock x:Name="TooltipTitle" Foreground="White" FontWeight="SemiBold" FontSize="13" />
                <TextBlock x:Name="TooltipInfo" Foreground="#B0FFFFFF" FontSize="11" />
                <TextBlock x:Name="TooltipLinks" Foreground="#90FFFFFF" FontSize="10" TextWrapping="Wrap" MaxWidth="200" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
